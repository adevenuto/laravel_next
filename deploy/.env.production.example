# Production env template for the Laravel backend on EC2.
# Copy to /var/www/laravel_next/backend/.env on the server and fill in the blanks.
# This file IS committed to the repo so the var names are discoverable; the real
# .env on the server is NEVER deployed (CI rsync excludes it).

APP_NAME="Next + Laravel"
APP_ENV=production
APP_KEY=                                       # filled in by `php artisan key:generate`
APP_DEBUG=false
APP_URL=http://REPLACE_WITH_ELASTIC_IP
FRONTEND_URL=http://REPLACE_WITH_ELASTIC_IP

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Database (RDS MySQL) -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_RDS_ENDPOINT              # e.g. laravel-next-rds.xxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=next_laravel
DB_USERNAME=laravel_next_admin
DB_PASSWORD=REPLACE_WITH_RDS_PASSWORD

# --- Session + Sanctum --------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false                    # HTTP only for v1; flip to true once HTTPS is in place
SESSION_SAME_SITE=lax

# Comma-separated. No protocol on stateful domains; full URL on CORS origins.
SANCTUM_STATEFUL_DOMAINS=REPLACE_WITH_ELASTIC_IP
CORS_ALLOWED_ORIGINS=http://REPLACE_WITH_ELASTIC_IP

# --- Cache + Queue ------------------------------------------------------
CACHE_DRIVER=database
QUEUE_CONNECTION=database

# --- Mail (deferred — using `log` driver until SES/SMTP is wired) ------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"
